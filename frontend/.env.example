# Local development (direct Neo4j driver in the app)
# NOTE: These values are embedded into the frontend bundle (because Vite exposes VITE_* to the browser).
# Do NOT use production credentials here.
VITE_NEO4J_URI=neo4j+s://<your-aura-id>.databases.neo4j.io
VITE_NEO4J_USER=<your-neo4j-user>
VITE_NEO4J_PASSWORD=<your-neo4j-password>
VITE_NEO4J_DATABASE=neo4j

# Optional: allow client-side update tracking in local dev only
# VITE_ENABLE_CLIENT_UPDATES=true

# Production / serverless (used by /api/neo4j/* functions)
# These are NOT exposed to the browser.
NEO4J_URI=neo4j+s://<your-aura-id>.databases.neo4j.io
NEO4J_USER=<your-neo4j-user>
NEO4J_PASSWORD=<your-neo4j-password>
NEO4J_DATABASE=neo4j

# NVD API key (if you later proxy NVD server-side)
# VITE_NIST_API_KEY=<your-nvd-api-key>
